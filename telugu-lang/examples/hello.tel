# hello.tel — మొదటి కార్యక్రమం (First program)
# Run: mana run examples/hello.tel

చెప్పు("నమస్కారం, ప్రపంచం!")

# Variables
వేరియబుల్ పేరు = "తెలుగు"
చెప్పు("ఇది " + పేరు + " భాష!")

# Constants
స్థిరం సంవత్సరం = 2024
చెప్పు("సంవత్సరం: " + సంవత్సరం)

# Simple arithmetic
వేరియబుల్ a = 10
వేరియబుల్ b = 32
వేరియబుల్ మొత్తం = a + b
చెప్పు("10 + 32 = " + మొత్తం)

# Function definition and call
పని స్వాగతం(పేరు) {
  చెప్పు("స్వాగతం, " + పేరు + "!")
}

స్వాగతం("అర్జున్")
స్వాగతం("ప్రియా")
